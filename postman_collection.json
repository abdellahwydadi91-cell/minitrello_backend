{
  "info": {
    "name": "MiniTrello API",
    "description": "Collection d'API pour tester tous les endpoints du backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"motDePasse\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "auth", "register"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Doe\",\n  \"prenom\": \"John\",\n  \"email\": \"john.doe@example.com\",\n  \"motDePasse\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Projets",
      "item": [
        {
          "name": "Créer un projet",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets?proprietaireId=1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets"],
              "query": [
                {
                  "key": "proprietaireId",
                  "value": "1"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Mon Premier Projet\",\n  \"description\": \"Description du projet\",\n  \"dateDebut\": \"2026-01-01\",\n  \"dateFin\": \"2026-12-31\"\n}"
            }
          }
        },
        {
          "name": "Obtenir tous les projets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Obtenir un projet par ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Mettre à jour un projet",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "1"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Projet Modifié\",\n  \"description\": \"Nouvelle description\",\n  \"dateDebut\": \"2026-02-01\",\n  \"dateFin\": \"2026-11-30\"\n}"
            }
          }
        },
        {
          "name": "Supprimer un projet",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "1"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Rechercher par titre",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/recherche?titre=Trello",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "recherche"],
              "query": [
                {
                  "key": "titre",
                  "value": "Trello"
                }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Colonnes",
      "item": [
        {
          "name": "Créer une colonne",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/1/colonnes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "1", "colonnes"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"À faire\",\n  \"description\": \"Tâches à faire\",\n  \"position\": 1\n}"
            }
          }
        },
        {
          "name": "Obtenir les colonnes du projet",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/v1/projets/1/colonnes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "projets", "1", "colonnes"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Tâches",
      "item": [
        {
          "name": "Créer une tâche",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/colonnes/1/taches",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "colonnes", "1", "taches"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titre\": \"Implémenter la feature X\",\n  \"description\": \"Description de la tâche\",\n  \"priorite\": \"HIGH\",\n  \"statut\": \"A_FAIRE\"\n}"
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "votre_token_jwt_ici",
      "type": "string"
    }
  ]
}

